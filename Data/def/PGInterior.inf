; ===============================================================================================
; Category Schaltknäufe
; ===============================================================================================

  <class type="OPTION">
    <group>INTERIEUR</group>
    <category>CATSchaltknauf</category>
    <btn>type=radio</btn>
    <name>Schaltknäufe</name>
    <file>CATSchaltknauf</file>
    <:KEYS>
      <CATSchaltknauf>
    </>
  </>

  <class type="OPTION" name="RADIOSchaltknaufWaehlhebel">
    <group>INTERIEUR</group>
    <parent>CATSchaltknauf</parent>
    <btn>type=radio</btn>
    <file>GASchaltknauf</file>
    <name>Serien-Schaltknauf</name>
    <:SCRIPTS>
      <:SELECT>
        <OFF "KEYPedaleAutomatik">
        <ON  "KEYPedaleSchaltgetriebe">
        <if  FindClassByKey( "KEYAlupedale" )^.Status != "0" do ON "KEYAlupedaleSchaltgetriebe">
      </>
    </>
    <:KEYS>
      <GASchaltknauf>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

  <class type="OPTION" name="RADIOSchaltknaufWaehlhebel">
    <group>INTERIEUR</group>
    <parent>CATWaehlhebel</parent>
    <btn>type=radio</btn>
    <file>GAWaehlhebel</file>
    <name>Serien-Wählhebel</name>
    <:SCRIPTS>
      <:SELECT>
        <OFF "KEYPedaleSchaltgetriebe">
        <ON  "KEYPedaleAutomatik">
        <if  FindClassByKey( "KEYAlupedale" )^.Status != "0" do ON "KEYAlupedaleAutomatik">
      </>
    </>
    <:KEYS>
      <GAWaehlhebel>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>


  %SCHALTKNAUF  [ "Leder-Schaltknauf schwarz", KEYSchaltknaufLederSchwarz ]
  %SCHALTKNAUF  [ "Serien-Schaltknauf", KEYSchaltknaufSerie ]
