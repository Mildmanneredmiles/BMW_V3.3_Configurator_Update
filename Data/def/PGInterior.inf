//====================================================================
// Makros
//====================================================================

$macro INTERIEUR_STATIC[ NAME, KEY ]

  <:OPTION>
    <group>INTERIEUR</group>
    <visibility>detail</visibility>
    <name>&NAME</name>
    <file>&KEY</file>
    <:KEYS>
      <&KEY>
    </>
  </>

$endmacro


$macro ILEISTE [ NAME, KEY ]

  <class type="OPTION" name="RADIOInterieurleisten">
    <parent>CATInterieurleisten</parent>
    <btn>type=radio</btn>
    <file>&KEY</file>
    <name>&NAME</name>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro

$macro ILEISTE_WERK [ NAME, KEY ]

  <class type="OPTION" name="RADIOInterieurleisten">
    <parent>CATInterieurleisten</parent>
    <btn>type=radio</btn>
    <file>&KEY</file>
    <name>&NAME</name>
    <name2>#ABWERK</name2>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro

$macro ILEISTE_DESELECTABLE [ NAME, KEY ]

  <class type="OPTION" name="RADIOInterieurleisten">
    <parent>CATInterieurleisten</parent>
    <btn>type=radio deselect=true</btn>
    <file>&KEY</file>
    <name>&NAME</name>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro


$macro LENKRAEDER [ NAME, KEY ]

  <class type="OPTION" name="RADIOLenkraeder">
    <parent>CATLenkraeder</parent>
    <btn>type=radio</btn>
    <file>&KEY</file>
    <name>&NAME</name>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro

$macro LENKRAEDERMF [ NAME, KEY ]

  <class type="OPTION" name="RADIOLenkraeder">
    <parent>CATLenkraederMultifunktion</parent>
    <btn>type=radio</btn>
    <file>&KEY</file>
    <name>&NAME</name>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro

$macro SCHALTKNAUF[ NAME, KEY, PARENT = "CATSchaltknauf" ]

  <class type="OPTION" name="RADIOSchaltknaufWaehlhebel">
    <parent>&PARENT</parent>
    <btn>type=radio</btn>
    <file>&KEY</file>
    <name>&NAME</name>
    <:SCRIPTS>
      <:SELECT>
        <OFF "KEYPedaleAutomatik">
        <OFF "KEYAlupedaleAutomatik">
        <ON  "KEYPedaleSchaltgetriebe">
        <lineif FindClassByKey( "KEYAlupedale" )^.Status != "0" do ON "KEYAlupedaleSchaltgetriebe">
      </>
    </>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro




$macro WAEHLHEBEL[ NAME, KEY ]

  <class type="OPTION" name="RADIOSchaltknaufWaehlhebel">
    <parent>CATWaehlhebel</parent>
    <btn>type=radio</btn>
    <file>&KEY</file>
    <name>&NAME</name>
    <:SCRIPTS>
      <:SELECT>
        <OFF "KEYPedaleSchaltgetriebe">
        <OFF "KEYAlupedaleSchaltgetriebe">
        <ON "KEYPedaleAutomatik">
        <lineif FindClassByKey( "KEYAlupedale" )^.Status != "0" do ON "KEYAlupedaleAutomatik">
      </>
    </>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro


$macro HANDBREMSGRIFFE[ NAME, KEY ]

  <class type="OPTION" name="RADIOHandbremsgriffe">
    <parent>CATHandbremsgriffe</parent>
    <btn>type=radio deselect=true</btn>
    <file>&KEY</file>
    <name>&NAME</name>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro

$macro FUSSMATTEN[ NAME, KEY ]

  <class type="OPTION" name="Radiomatten">
        <parent>CATFussmatten</parent>
        <btn>type=radio deselect=true</btn>
        <visibility>detail</visibility>
        <name>&NAME</name>
        <file>&KEY</file>
        <:KEYS>
          <&KEY>
        </>
      </>

$endmacro

$macro FUSSSTUETZEN[ NAME, KEY ]

  <class type="OPTION" name="RADIOFussstuetze">
        <parent>CATFussstuetzen</parent>
        <btn>type=radio deselect=true</btn>
        <name>&NAME</name>
        <file>&KEY</file>
        <:KEYS>
          <&KEY>
        </>
        <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
      </>


$endmacro

