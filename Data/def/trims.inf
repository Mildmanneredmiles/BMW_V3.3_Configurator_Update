    %E53_POLSTER [ "Dunkelgrau", FxxDG, PolsterDunkelgrau, ITafelUntenHellgrau, ITafelObenSchwarz, ASaeulenGrau ]

    %E63_POLSTER [ "Creambeige", FxxGE, "asaeulen-creambeige" ]
    %E63_POLSTER [ "Chateau",    FxxCH, "asaeulen-himmelgrau" ]
    %E63_POLSTER [ "Schwarz",    FxxSW, "asaeulen-himmelgrau" ]
