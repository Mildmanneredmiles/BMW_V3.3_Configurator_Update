$macro E60_POLSTER [ NAME, KEYCODE, POLSTER, ZWEITFARBE, ITAFELOBEN, ASAEULEN ]

    <class type="OPTION" name="RADIOPolsterung">
      <group>INTERIEUR</group>
      <parent>CATInterieurfarben</parent>
      <UINameIdentifier>UIUpholstery</UINameIdentifier>
      <name>&NAME</name>
      <btn>type=radio</btn>
      <iconfile>&KEYCODE</iconfile>
      <:color>
        <trim["polster"]>&POLSTER</trim["polster"]>
        <trim["asaeulen"]>&ASAEULEN</trim["asaeulen"]>
        <trim["itafeloben"]>&ITAFELOBEN</trim["itafeloben"]>
        <trim["konsole"]>&ZWEITFARBE</trim["konsole"]>
        <trim["teppich"]>&ZWEITFARBE</trim["teppich"]>
      </color>
      <:KEYS>
        <KEYE60&KEYCODE>
        <&KEYCODE>
      </>
      <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
    </OPTION>

$endmacro

  <:OPTION>
    <group>INTERIEUR</group>
    <category>CATInterieurfarben</category>
    <name>Interieurfarben</name>
    <file>CATInterieurfarben</file>
    <:KEYS>
      <CATInterieurfarben>
    </>
  </>

<:TRIMS>

    %E60_POLSTER [ "Schwarz",        FxxSW, Schwarz, SchwarzII, ITafelObenSchwarz, Grau ]
    %E60_POLSTER [ "Grau",           FxxAD, Grau, Grau, ITafelObenBasaltgrau, Grau ]
    %E60_POLSTER [ "Beige",          FxxBA, Beige, Beige, ITafelObenSchwarz, Beige ]
    %E60_POLSTER [ "Amethyst",       FxxRH, Amethyst, SchwarzII, ITafelObenSchwarz, Grau ]
    %E60_POLSTER [ "Trüffelbraun",   FxxTE, Trueffelbraun, Trueffelbraun, ITafelObenSchwarz, Grau ]
    %E60_POLSTER [ "Kastanienbraun", FxxRK, Kastanienbraun, SchwarzII, ITafelObenSchwarz, Grau ]
    %E60_POLSTER [ "Anthrazit",      FxxAT, Anthrazit, SchwarzII, ITafelObenSchwarz, Grau ]

    %E46_POLSTER [ "Schwarz", FxxSW, PolsterSchwarz, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenGrau, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Grau", FxxTT, PolsterGrau, ITafelUntenGrau, ITafelObenSchwarz, ASaeulenGrau, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Anthrazit", FxxAT, PolsterAnthrazit, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenGrau, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Hellbeige", FxxHC, PolsterHellbeige, ITafelUntenHellbeige, ITafelObenSchwarz, ASaeulenHellbeige, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Naturbraun", FxxNG, PolsterNaturbraun, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenHellbeige, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Brombeer", FxxBB, PolsterBrombeer, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenGrau, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Lightgelb", FxxLT, PolsterLightgelb, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenAnthrazit, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Lavanda", FxxSE, PolsterLavenda, ITafelUntenSchwarz, ITafelObenLavenda, ASaeulenAnthrazit, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Orange", FxxPP, PolsterOrange, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenAnthrazit, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Poeticblue", FxxAU, PolsterPoeticblue, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenGrau, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Taninrot", FxxTD, PolsterTaninrot, ITafelUntenSchwarz, ITafelObenTaninrot, ASaeulenGrau, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Traumrot", FxxTL, PolsterTraumrot, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenGrau, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Topasblau", FxxTO, PolsterTopasblau, ITafelUntenSchwarz, ITafelObenTopasblau, ASaeulenAnthrazit, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Pistazie", FxxPI, PolsterPistazie, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenAnthrazit, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Technograu", FxxTF, PolsterTechnograu, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenGrau, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Mysticblau", FxxMF, PolsterMysticblau, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenAnthrazit, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Schwarzgrau", FxxTM, PolsterSchwarzgrau, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenAnthrazit, KEYInterieurLeisteTitan ]
    %E46_POLSTER [ "Kieselgrau", FxxKA, PolsterKieselgrau, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenAnthrazit, KEYInterieurLeisteTitan ]
    ;%E46_POLSTER [ "Blau/Schwarz", FxxBL, PolsterAnthrazit, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenAnthrazit, KEYInterieurLeisteVelvetblau ]
    ;%E46_POLSTER [ "Rot/Schwarz", FxxRE, PolsterAnthrazit, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenAnthrazit, KEYInterieurLeisteImolarot ]


    %E39_POLSTER [ "Schwarz", FxxSW, PolsterSchwarz, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenGrau, ArmlehneSchwarz ]
    %E39_POLSTER [ "Grau", FxxTT, PolsterGrau, ITafelUntenGrau, ITafelObenSchwarz, ASaeulenGrau, ArmlehneGrau ]
