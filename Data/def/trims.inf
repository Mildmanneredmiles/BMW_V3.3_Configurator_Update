        <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
      </>
$endmacro

$macro E87_POLSTER [ TYP, NAME, LAYER, KEY, C1, C2, C3, C4, C5 ]

    <class type="OPTION" name="RADIOPolsterung">
      <group>INTERIEUR</group>
      <parent>CATInterieurfarben</parent>
      <UINameIdentifier>UIUpholstery</UINameIdentifier>
        <name>&NAME</name>
        <name2>&TYP</name2>
        <btn>type=radio</btn>
        <file>&KEY</file>
        <iconfile>&KEY</iconfile>
        <:color>
          <trim["polster"]>&KEY</trim["polster"]>
          <trim["welt1"]>&C1</trim["welt1"]>
          <trim["welt2"]>&C2</trim["welt2"]>
          <trim["teppich"]>&C3</trim["teppich"]>
          <trim["asaeulen"]>&C4</trim["asaeulen"]>
          <trim["itafel"]>&C5</trim["itafel"]>
        </>
        <:SCRIPTS>
          <:SELECT>
            <LAYEROFF "layermotiongrau">
            <LAYEROFF "layermotiongsonora">
            <LAYEROFF "layermotionsydneyblau">
            <LAYEROFF "layermotiongraphit">
            <LAYERON  "&LAYER">
          </>
        </SCRIPTS>
        <class type="KEYS">
          <KEYE87&KEY>
          <&KEY>
        </>
      <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
    </>

$endmacro


