

$macro TRIM_E90 [ TYP, NAME, KEY, C1, C2, C3 ,C4, layer ]

    <class type="OPTION" name="RADIOPolsterung">
        <group>INTERIEUR</group>
        <parent>CATInterieurfarben</parent>
        <UINameIdentifier>UIUpholstery</UINameIdentifier>
        <name>&NAME</name>
        <name2>&TYP</name2>
        <btn>type=radio</btn>
        <file>&KEY</file>
        <code>&KEY</code>
        <:SCRIPTS>
          <:SELECT>
            <OFF "KEYSportsitz">
            <LAYERON  "&layer">
          </>
        </SCRIPTS>
        <:color>
          <trim["polster"]>&KEY</trim["polster"]>
          <trim["interieur"]>&C1</trim["interieur"]>
          <trim["teppich"]>&C2</trim["teppich"]>
          <trim["asaeulen"]>&C3</trim["asaeulen"]>
          <trim["rest"]>&C4</trim["rest"]>
        </>
        <class type="KEYS">
          <KEYE90&KEY>
          <&KEY>
        </>
        <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
      </>

$endmacro

$macro TRIM_E90Sport [ TYP, NAME, KEY, C1, C2, C3 ,C4, layer ]

    <class type="OPTION" name="RADIOPolsterung">
        <group>INTERIEUR</group>
        <parent>CATInterieurfarben</parent>
        <UINameIdentifier>UIUpholstery</UINameIdentifier>
        <name>&NAME</name>
        <name2>$T[Sportsitz] &TYP</name2>
        <btn>type=radio</btn>
        <file>&KEY</file>
        <code>&KEY</code>
        <:SCRIPTS>
          <:SELECT>
            <ON  "KEYSportsitz">
            <LAYERON  "&layer-sport">
          </>
        </SCRIPTS>
        <:color>
          <trim["polster"]>&KEY</trim["polster"]>
          <trim["interieur"]>&C1</trim["interieur"]>
          <trim["teppich"]>&C2</trim["teppich"]>
          <trim["asaeulen"]>&C3</trim["asaeulen"]>
          <trim["rest"]>&C4</trim["rest"]>
        </>
        <class type="KEYS">
          <KEYE90&KEY-Sport>
          <&KEY>
        </>
        <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
      </>

$endmacro

$macro TRIM_E65_LCI [ TYP, NAME, KEY, AS, BS, IT ,TE, TU, MI, IU, TV, LE, layer ]
      <:OPTION name"RADIOPolsterE65_LCI">
        <group>INTERIEUR</group>
        <parent>CATInterieurfarben</parent>
        <name>&NAME</name>
        <name2>&TYP</name2>
        <UINameIdentifier>UIUpholstery</UINameIdentifier>
        <btn>type=radio</btn>
        <:SCRIPTS>
          <:SELECT>
            <LAYERON  "&layer">
            <OFF  "KEYKomfortsitz", "KEYKlimasitz">
            <HIDE "KEYKomfortsitz", "KEYKlimasitz">
          </>
        </SCRIPTS>
        <:color>
          <trim["polster"]>&KEY</trim["polster"]>
          <trim["asaeulen"]>&AS</trim["asaeulen"]>
          <trim["bsaeulen"]>&BS</trim["bsaeulen"]>
          <trim["itafeloben"]>&IT</trim["itafeloben"]>
          <trim["teppich"]>&TE</trim["teppich"]>
          <trim["tuer"]>&TU</trim["tuer"]>
          <trim["mittelkonsole"]>&MI</trim["mittelkonsole"]>
          <trim["itafelunten"]>&IU</trim["itafelunten"]>
          <trim["tuerunten"]>&TV</trim["tuerunten"]>
          <trim["lenkrad"]>&LE</trim["lenkrad"]>
        </>
        <class type="KEYS">
          <&KEY>
          <KEYE65LCI&KEY>
        </>
        <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
      </>
$endmacro

