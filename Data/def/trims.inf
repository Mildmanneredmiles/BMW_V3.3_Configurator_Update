    %E39_POLSTER [ "Sandbeige", FxxSN, PolsterSandbeige, ITafelUntenSandbeige, ITafelObenDunkelbeige, ASaeulenHellbeige, ArmlehneSandbeige]
    %E39_POLSTER [ "Sandbeige/Schwarz", FxxSN, PolsterSandbeige, ITafelUntenSandbeige, ITafelObenSchwarz, ASaeulenHellbeige, ArmlehneSandbeige]

    %E53_POLSTER [ "Schwarz", FxxSW, PolsterSchwarz, ITafelUntenSchwarz, ITafelObenSchwarz, ASaeulenGrau ]
    %E53_POLSTER [ "Grau", FxxTT, PolsterGrau, ITafelUntenHellgrau, ITafelObenSchwarz, ASaeulenGrau ]
