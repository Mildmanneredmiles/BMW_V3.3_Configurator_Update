            <*class type="DEF" ref="Z3 roadster">
            <:AUTOSCRIPT>
              <DEFAULT "KEYFelge64">
              <HIDE    "KEYFelgeStahlZ3">
            </class>

            <:KEYS>
              <CN51>
              <CN52>
            </>
          </>
        </MOTORS>
      </>
