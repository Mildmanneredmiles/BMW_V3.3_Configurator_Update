
$macro KOMM_STANDARD[ NAME, KEY ]

  <:OPTION>
    <group>KOMMUNIKATION</group>
    <name>&NAME</name>
    <file>&KEY</file>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro

$macro KOMM_STATIC[ NAME, KEY ]
  <:OPTION>
    <group>KOMMUNIKATION</group>
    <visibility>detail</visibility>
    <name>&NAME</name>
    <file>&KEY</file>
    <:KEYS>
      <&KEY>
    </>
  </>

$endmacro

$macro KOMM_RADIO_STATIC[ NAME, KEY, FILE ]
  <:OPTION name="RADIORadio">
    <group>KOMMUNIKATION</group>
    <btn>type=radio deselect=true</btn>
    <visibility>detail</visibility>
    <name>&NAME</name>
    <file>&FILE</file>
    <:KEYS>
      <&KEY>
    </>
  </>

$endmacro

$macro RADIO[ NAME, KEY ]

  <class type="OPTION" name="RADIORadio">
    <group>KOMMUNIKATION</group>
    <btn>type=radio deselect=true</btn>
    <name>&NAME</name>
    <file>&KEY</file>
    <:KEYS>
      <&KEY>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro

$macro BORDMONITORSYSTEM[ NAME, KEY ]

  <class type="OPTION" name="RADIOBordmonitorsysteme">
    <group>KOMMUNIKATION</group>
    <btn>type=radio deselect=true</btn>
    <name>&NAME</name>
    <file>&KEY</file>
    <:KEYS>
      <&KEY>
    </>
    <:SCRIPTS>
      <:AFTERSELECT>
      	<ON "KEYBordmonitor">
      </>
$ifndef BORDMONITOR_VISIBLE
      <:AFTERDESELECT>
        <case selected KEYBordmonitor OFF "KEYBordmonitor">
      </>
$endif
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>

$endmacro

$macro AUTOTELEFONE[ NAME, KEY ]

  <class type="OPTION" name="RADIOAutoTelefon">
        <parent>CATAutotelefone</parent>
        <btn>type=radio deselect=true</btn>
        <visibility>detail</visibility>
        <name>&NAME</name>
        <file>&KEY</file>
        <:KEYS>
          <&KEY>
        </>
      </>

$endmacro

$macro FREISPRECHUNIVERSELL[ NAME, KEY ]

  <class type="OPTION" name="RADIOAutoTelefon">
        <parent>CATFreisprechuniversell</parent>
        <btn>type=radio deselect=true</btn>
        <visibility>detail</visibility>
        <name>&NAME</name>
        <file>&KEY</file>
        <:KEYS>
          <&KEY>
        </>
      </>

$endmacro

$macro TELEFONKONSOLE[ NAME, KEY ]

  <class type="OPTION" name="RADIOTelefonkonsole">
        <parent>CATFreisprechSeitenkonsole</parent>
        <btn>type=radio deselect=true</btn>
        <name>&NAME</name>
        <file>&KEY</file>
        <:SCRIPTS>
	  <:SELECT>
	    <ON "KEYTelefonkonsole">
          </>
	  <:OFF>
	    <OFF "KEYTelefonkonsole">
	  </>
        </>
        <:KEYS>
          <&KEY>
        </>
      </>

$endmacro

