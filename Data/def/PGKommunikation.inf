  %TELEFONKONSOLE[ "Telefonkonsole hellbeige", KEYTelefonkonsoleHellbeige ]
  %TELEFONKONSOLE[ "Telefonkonsole marineblau", KEYTelefonkonsoleMarineblau ]
  %TELEFONKONSOLE[ "Telefonkonsole sandbeige", KEYTelefonkonsoleSandbeige ]
  %TELEFONKONSOLE[ "Telefonkonsole englischgrün", KEYTelefonkonsoleEnglischgruen ]
  %TELEFONKONSOLE[ "Telefonkonsole beige", KEYTelefonkonsoleBeige ]

  <:OPTION>
    <:KEYS>
