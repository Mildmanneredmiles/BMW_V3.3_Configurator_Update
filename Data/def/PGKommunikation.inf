  </>

; ===============================================================================================
; Autoradio / Navigation / Bordmonitor
; ===============================================================================================

  %RADIO[ "BMW Radio Business CD", 		KEYRadioBusinessCD ]
  %RADIO[ "BMW Radio Professional", 		KEYRadioProfessional ]
  %RADIO[ "BMW Radio Professional CD", 		KEYRadioProfessionalCD ]
  %RADIO[ "BMW Radio Business Kassette", 	KEYRadioBusinessKassette ]
  %RADIO[ "BMW Radio Reverse", 			KEYRadioReverse ]
  %RADIO[ "$T[BMW Radionavigation] Indianapolis",   KEYRadionavigationIndianapolis ]
  %RADIO[ "BMW Radio Professional MD", 		KEYMDLaufwerk ]
  %RADIO[ "BMW Radionavigation", 		KEYRadioNavigation ]

  %KOMM_RADIO_STATIC[ "BMW Business Kassette", 	KEYRadioBusinessKassetteDetailOnly, KEYRadioBusinessKassette  ]
  %KOMM_RADIO_STATIC[ "BMW Business CD", 	KEYRadioBusinessCDDetailOnly, 	    KEYRadioBusinessCD  ]
  %KOMM_RADIO_STATIC[ "BMW Business MD", 	KEYRadioBusinessMDDetailOnly,       KEYRadioBusinessMD  ]

  %BORDMONITORSYSTEM[ "Navigationssystem mit MD-Laufwerk", KEYNavigationssystemMD ]
  %BORDMONITORSYSTEM[ "Navigationssystem mit CD-Laufwerk", KEYNavigationssystemCD ]
  %BORDMONITORSYSTEM[ "Navigationssystem Professional",    KEYNavigationssystem ]
  %BORDMONITORSYSTEM[ "TV-Funktion", 			   KEYTVFunktion ]


  <:OPTION name="RADIORadio">
    <visibility>0</visibility>
    <btn>type=radio deselect=true</btn>
    <group>KOMMUNIKATION</group>
    <file>KEYBordmonitor</file>
    <name>Bordmonitor</name>
    <:KEYS>
      <KEYBordmonitor>
    </>
    <:SCRIPTS>
      <:SELECT>
        <case selected KEYFrontkameraNoNavi OFF "KEYFrontkameraNoNavi">
	<case selected KEYRueckfahrkameraNoNavi OFF "KEYRueckfahrkameraNoNavi">
      </>
      <:AFTERDESELECT>
        <case selected KEYTVFunktion OFF "KEYTVFunktion">
        <case selected KEYFrontkamera OFF "KEYFrontkamera">
        <case selected KEYRueckfahrkamera OFF "KEYRueckfahrkamera">
        <case selected KEYNavigationssystem OFF "KEYNavigationssystem">
        <case selected KEYNavigationssystemCD OFF "KEYNavigationssystemCD">
        <case selected KEYNavigationssystemMD OFF "KEYNavigationssystemMD">
      </>
    </>
    <*class type="VIEWS" ref="DEFAULT_INTERIOR_VIEWS">
  </>



; ===============================================================================================
; Audio/Video/Sound etc.
