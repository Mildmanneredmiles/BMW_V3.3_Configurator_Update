  <class type="OPTION">
    <group>KOMMUNIKATION</group>
    <category>CATAutotelefone</category>
    <btn>type=radio</btn>
    <name>BMW Autotelefone</name>
    <file>CATAutotelefone</file>
    <:KEYS>
      <CATAutotelefone>
    </>
  </>

 %AUTOTELEFONE [ "BMW Autotelefon Cordless", KEYAutotelefonCordless ]
 %AUTOTELEFONE [ "BMW Autotelefon Professional", KEYAutotelefonProfessional ]
