//====================================================================
// Makros
//====================================================================

$macro EXTERIEUR_STATIC[ NAME, KEY ]

  <:OPTION>
    <group>EXTERIEUR</group>
    <visibility>detail</visibility>
    <name>&NAME</name>
    <file>&KEY</file>
    <:KEYS>
      <&KEY>
    </>
  </>

$endmacro

      <:OPTION>
        <group>EXTERIEUR</group>
        <name>Exterieurumfänge in Wagenfarbe</name>
        <file>KEYTeileWagenfarbe</file>
        <:KEYS>
          <KEYTeileWagenfarbe>
          <S0321>
        </>
        <*class type="VIEWS" ref="DEFAULT_EXTERIOR_VIEWS">
	<prio>990</prio>
      </>

     %EXTERIEUR_STATIC [ "Hardtop-Transportwagen", KEYHardtopTransportwagen ]

     <:OPTION>
      <file>KEYE65V12Modifications</file>
       <:KEYS>
         <KEYE65V12Modifications>
       </KEYS>
     </>

     <class type="OPTION" NAME="WeisseBlinker">
       <group>EXTERIEUR</group>
       <name>Weisse Blinkleuchten</name>
       <file>KEYWeisseBlinker</file>
       <:KEYS>
         <KEYWeisseBlinker>
         <S0785>
       </class>
       <*class type="VIEWS" ref="DEFAULT_EXTERIOR_VIEWS">
     </class>

     <class type="OPTION" name="AERODYNAMIK">
       <group>EXTERIEUR</group>
       <name>Aerodynamikpaket</name>
       <file>KEYAerodynamikpaket</file>
       <btn>type=radio deselect=true</btn>
       <:KEYS>
         <KEYAerodynamikpaket>
       </>
       <*class type="VIEWS" ref="DEFAULT_EXTERIOR_VIEWS">
       <:SCRIPTS>
         <:SELECT>
           <ON   "KEYNebelscheinwerfer">
           <OFF  "KEYTrittbrett">
           <lineif ecode = "E83" do ON "KEYAuspuffrohrblendeChrom">
           <OFF "KEYSchmutzfaenger", "KEYSchmutzfaengerVorne", "KEYSchmutzfaengerHinten">
         </>
         <:OFF>
           <lineif ecode = "E83" do OFF "KEYAuspuffrohrblendeChrom">
         </>
       </>
     </>

     <class type="OPTION" name="AERODYNAMIK">
       <group>EXTERIEUR</group>
       <name>$T[Aerodynamikpaket] II</name>
       <file>KEYAerodynamikpaketII</file>
       <btn>type=radio deselect=true</btn>
       <:KEYS>
         <KEYAerodynamikpaketII>
       </>
       <*class type="VIEWS" ref="DEFAULT_EXTERIOR_VIEWS">
       <:SCRIPTS>
         <:ON>
           <ON  "KEYNebelscheinwerfer">
           <lineif ecode = "E83" do ON "KEYAuspuffrohrblendeChrom">
           <OFF "KEYSchmutzfaenger", "KEYSchmutzfaengerVorne", "KEYSchmutzfaengerHinten">
         </>
         <:OFF>
           <lineif ecode = "E83" do OFF "KEYAuspuffrohrblendeChrom">
         </>
       </>
     </>

     <class type="OPTION" name="AERODYNAMIK">
       <group>EXTERIEUR</group>
       <name>M Aerodynamikpaket</name>
       <file>KEYMAerodynamikpaket</file>
       <btn>type=radio deselect=true</btn>
       <:KEYS>
         <KEYMAerodynamikpaket>
       </>
       <:SCRIPTS>
         <:SELECT>
           <ON  "KEYNebelscheinwerfer">
           <OFF "KEYTrittbrett">
           <OFF "KEYTitanLineExterieur">
           <OFF "KEYStossleisten">
           <OFF "KEYSchmutzfaenger", "KEYSchmutzfaengerVorne", "KEYSchmutzfaengerHinten">
         </>
         <:DESELECT>
          <OFF "KEYAufsatzteileMAerodynamikpaket">
          <OFF "KEYDiffusor">
         </>
       </>
       <*class type="VIEWS" ref="DEFAULT_EXTERIOR_VIEWS">
     </>

     <:OPTION>
       <group>EXTERIEUR</group>
       <name>Aufsatzteile Frontschürze</name>
       <file>KEYAufsatzteileMAerodynamikpaket</file>
       <:KEYS>
         <KEYAufsatzteileMAerodynamikpaket>
       </>
       <:SCRIPTS>
         <:ON>
           <NEEDS [ "KEYMAerodynamikpaket", "KEYHeckspoiler" ] ?ON "%AUTOINSERT">
         </>
       </>
       <:VIEWS>
	 <frontseite>2</frontseite>
         <seite>1</seite>
       </>
     </>

     <:OPTION>
       <group>EXTERIEUR</group>
       <name>Diffusor</name>
       <file>KEYDiffusor</file>
       <:KEYS>
         <KEYDiffusor>
       </>
       <:SCRIPTS>
         <:ON>
           <NEEDS [ "KEYMAerodynamikpaket" ] ?ON "%AUTOINSERT">
         </>
       </>
       <:VIEWS>
	 <heckseite>2</heckseite>
       </>
     </>

     <:OPTION name="AERODYNAMIK">
       <group>EXTERIEUR</group>
       <btn>type=radio deselect=true</btn>
       <name>Aerodynamik-Komponenten</name>
       <file>KEYAerodynamikKomponenten</file>
       <:KEYS>
         <KEYAerodynamikKomponenten>
       </>
       <:SCRIPTS>
         <:SELECT>
           <OFF "KEYSchmutzfaenger", "KEYSchmutzfaengerVorne", "KEYSchmutzfaengerHinten">
         </>
       </>
       <*class type="VIEWS" ref="DEFAULT_EXTERIOR_VIEWS">
     </>

     <:OPTION>
       <group>EXTERIEUR</group>
       <name>Stoßleisten</name>
       <file>KEYStossleisten</file>
       <:KEYS>
         <KEYStossleisten>
       </>
       ; nicht in Radio mit Aeropaket wegen Aerodynamik-Komponenten
       <:SCRIPTS>
         <:SELECT>
           <case selected KEYMAerodynamikpaket OFF "KEYMAerodynamikpaket">
         </>
       </>
       <*class type="VIEWS" ref="DEFAULT_EXTERIOR_VIEWS">
     </>

     <:OPTION>
       <group>EXTERIEUR</group>
